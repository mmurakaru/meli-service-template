{
  "name": "meli-service-template",
  "version": "0.1.0",
  "description": "Walking-skeleton Effect.ts service architecture for meli backend services",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.ts",
    "start": "cross-env NODE_ENV=production node --env-file-if-exists=.env src/server.ts",
    "typecheck": "tsc",
    "lint": "biome check . && tsc && node --run docs:validate",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate --config=./src/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=./src/db/drizzle.config.ts",
    "docs:generate": "node scripts/generate-env-docs.ts",
    "docs:validate": "node scripts/validate-env-docs.ts",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@effect/opentelemetry": "0.64.0",
    "@effect/platform": "0.97.0",
    "@effect/sql": "0.52.0",
    "@effect/sql-drizzle": "0.51.0",
    "@effect/sql-pg": "0.53.0",
    "@fastify/cors": "11.3.0",
    "@fastify/helmet": "13.1.0",
    "@fastify/jwt": "10.2.0",
    "@fastify/swagger": "9.8.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-prometheus": "0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-logs": "0.220.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/sdk-trace-node": "2.9.0",
    "@opentelemetry/sdk-trace-web": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@scalar/fastify-api-reference": "1.62.9",
    "bullmq": "5.80.9",
    "drizzle-orm": "0.45.2",
    "effect": "3.22.0",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "fastify-type-provider-zod": "7.0.0",
    "ioredis": "5.11.1",
    "pg": "8.22.0",
    "posthog-node": "5.45.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@effect/vitest": "0.30.0",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "cross-env": "10.1.0",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  }
}
